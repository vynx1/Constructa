# =============================================================================
# Construca — web app environment template.
# Copy to `.env` (already git-ignored) and fill in only what you want live.
#
#   cp .env.example .env
#
# THE APP RUNS WITH ZERO KEYS. Every integration below is env-guarded: with a
# key blank, that service falls back to seeded/mock data and the map + deep-dive
# flow still works end-to-end. Add keys to switch each piece to "live".
#
# Setup walkthroughs for each key live in docs/MAP_SYSTEM.md §"API setup".
# =============================================================================

# --- Core state / cache ------------------------------------------------------
# Redis backs the map cache (map:state:*, map:district:*), session scrapes, and
# the ASI:One guide cache. Local: `docker compose up redis` or Homebrew redis.
# Hosted: Upstash / Redis Cloud give a redis:// (or rediss://) URL.
REDIS_URL=redis://localhost:6379

# --- Anthropic Claude --------------------------------------------------------
# Used for one-sentence district justifications + compliance plans.
# Get a key: https://console.anthropic.com/ -> Settings -> API Keys.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# --- Browserbase (headless web extraction, master plan §3B) ------------------
# Powers the live deep-dive scrape pass (permit portals, zoning GIS, sentiment).
# 1. Sign up: https://www.browserbase.com/
# 2. Dashboard -> Settings -> copy your API key AND your Project ID.
# 3. Live scraping also needs the SDK installed:  npm i @browserbasehq/sdk playwright-core
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Fetch.ai ASI:One (agent router, master plan §3C) ------------------------
# Synthesizes the land-buying guide; falls back to the Agentverse marketplace.
# 1. Create an account: https://asi1.ai/  (or https://agentverse.ai/)
# 2. Open the developer dashboard -> API Keys -> create a key (starts "sk_...").
# 3. ASI:One is OpenAI-compatible; the base URL rarely changes.
ASI_ONE_API_KEY=
ASI_ONE_BASE_URL=https://api.asi1.ai/v1
ASI_ONE_MODEL=asi1

# --- Arize (observability, BUILD_PLAN §1) ------------------------------------
# Logs every agent call; a failure/low-confidence span is the ASI:One fallback
# trigger. Without keys, spans are logged to stdout instead.
# 1. Sign up: https://app.arize.com/
# 2. Space Settings -> copy Space ID + API Key.
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# --- Python agent service ----------------------------------------------------
# Where the web API proxies /api/agents/* (the 6 uAgents live here).
AGENT_SERVICE_URL=http://localhost:8000

# --- Auth (optional; from the original README) -------------------------------
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
