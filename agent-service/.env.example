# Agent-service environment template. Copy to `.env`.
#   cp .env.example .env
PORT=8000
RELOAD=1

# Shared with the web API.
REDIS_URL=redis://localhost:6379

# Origin allowed for CORS (the web app).
WEB_ORIGIN=http://localhost:3000

# --- Fetch.ai (ASI:One router + uAgents, master plan §3C) --------------------
# The agent service hosts the uAgents and can run the ASI:One scoring pass.
ASI_ONE_API_KEY=
ASI_ONE_BASE_URL=https://api.asi1.ai/v1
ASI_ONE_MODEL=asi1
# Seed phrase for the deterministic uAgent identity (uagents library).
FETCHAI_AGENT_SEED=

# --- Browserbase (headless scraping for the heatmap pipeline) ----------------
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Arize (observability) ---------------------------------------------------
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# --- Anthropic Claude (district justifications) ------------------------------
ANTHROPIC_API_KEY=
# Agentic model => real Agentverse agent routing (records interactions).
ASI_ONE_AGENTIC_MODEL=asi1-agentic

# --- Agentverse mailbox (REQUIRED for interaction counters) -----------------
# Write/mailbox-scoped key from agentverse.ai. Without it, messages to the 6
# hosted specialist agents are NOT delivered and interaction counters stay flat.
# In .env use NO quotes:  AGENTVERSE_API_KEY=eyJhbGc...
AGENTVERSE_API_KEY=
# Deterministic sender identity for the dispatcher (any stable string).
SENDER_SEED=constructa-interaction-driver-seed-v1

# Base URL the web app uses to reach the agent service dispatcher.
AGENT_SERVICE_URL=http://localhost:8000
