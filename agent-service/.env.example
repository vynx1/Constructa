# Agent-service environment template. Copy to `.env`.
PORT=8000
RELOAD=1

# Shared with the web API.
REDIS_URL=redis://localhost:6379

# Origin allowed for CORS (the web app).
WEB_ORIGIN=http://localhost:3000

# Deepgram (voice transcription).
DEEPGRAM_API_KEY=

# Fetch.ai uAgent (compliance watchdog).
FETCHAI_AGENT_SEED=
